{
  "version": 2,
  "functions": {
    "api/clients.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/update.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/debrief.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
